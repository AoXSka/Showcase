# ─────────────────────────────────────────────────────────────────
# Portfolio — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Public site URL (used for OG meta tags and canonical links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.dev

# Contact form endpoint (optional — for a serverless contact route)
# CONTACT_FORM_ENDPOINT=https://api.yourdomain.dev/contact

# Analytics (optional — privacy-first, e.g. Plausible or Fathom)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
